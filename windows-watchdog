#!/usr/bin/env bash
# windows-watchdog: Monitors the VM and triggers host reset if VM crashes
# while holding the GPU.

set -euo pipefail

STATE_FILE="/etc/passthrough/passthrough.conf"
[[ -f "${STATE_FILE}" ]] || { echo "No state file found." >&2; exit 1; }
source "${STATE_FILE}"

VM_NAME="${VM_NAME:-windows}"
GPU_PCI="${GPU_PCI:-}"

# Function to check if the VM is actually running
is_vm_running() {
  [[ "$(virsh -c qemu:///system domstate "${VM_NAME}" 2>/dev/null || true)" == "running" ]]
}

# Function to check if GPU is bound to vfio-pci
is_gpu_in_vfio() {
  [[ -n "${GPU_PCI}" ]] && lspci -nnk -s "${GPU_PCI}" | grep -q "vfio-pci"
}

echo "Starting windows-watchdog for ${VM_NAME}..."

while true; do
  if ! is_vm_running; then
    if is_gpu_in_vfio; then
      echo "[$(date)] VM ${VM_NAME} is down but GPU is still in VFIO mode. Triggering reset-host..."
      /usr/local/bin/passthrough-reset-host
    fi
  fi
  sleep 10
done
