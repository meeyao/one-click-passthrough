#!/usr/bin/env bash
# windows — VM lifecycle manager for one-click-passthrough.
#
# Usage:
#   ./windows              — smart start (auto-detects stage and does the right thing)
#   ./windows start        — same as above
#   ./windows stream       — headless start for Sunshine/Moonlight streaming
#   ./windows headless     — alias for stream
#   ./windows sunshine     — print Sunshine/Moonlight connection instructions
#   ./windows create       — create the initial Spice install VM
#   ./windows attach-gpu   — finalize: rewrite XML for GPU passthrough
#   ./windows stop         — ACPI shutdown
#   ./windows destroy      — force-kill
#   ./windows reset        — hard reset
#   ./windows reboot       — guest reboot
#   ./windows status       — show stage + VM state
#   ./windows next         — print what the next step is
#   ./windows xml          — dump libvirt XML
#
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
STATE_FILE="${STATE_FILE:-/etc/passthrough/passthrough.conf}"

if [[ -f "${STATE_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${STATE_FILE}"
fi

VM_NAME="${VM_NAME:-windows}"
URI="${LIBVIRT_URI:-qemu:///system}"
ACTION="${1:-go}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

confirm() {
  local message="$1"
  local default="${2:-n}"
  local suffix='[y/N]'
  local answer
  [[ "${default}" == "y" ]] && suffix='[Y/n]'
  read -r -p "${message} ${suffix}: " answer
  answer="${answer:-$default}"
  [[ "${answer}" =~ ^[Yy]([Ee][Ss])?$ ]]
}

run_maybe_sudo() {
  if [[ "${EUID}" -eq 0 ]]; then
    "$@"
  else
    local esc
    for esc in sudo doas pkexec; do
      command -v "${esc}" >/dev/null 2>&1 && { "${esc}" "$@"; return; }
    done
    "$@"
  fi
}

# ---------------------------------------------------------------------------
# Stage actions
# ---------------------------------------------------------------------------

passthrough_create_vm() {
  run_maybe_sudo /usr/local/bin/passthrough-create-vm "${1:-}" "${2:-}"
  launch_spice_viewer
}

passthrough_attach_gpu() {
  # Delegate to the installed helper generated by passthrough-setup.sh.
  # This does the full Python XML rewrite + anticheat flags + GPU device attach.
  if [[ -x /usr/local/bin/passthrough-attach-gpu ]]; then
    run_maybe_sudo /usr/local/bin/passthrough-attach-gpu
  else
    echo "passthrough-attach-gpu not found." >&2
    echo "Re-run: sudo ${SCRIPT_DIR}/passthrough-setup.sh" >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# GPU release preflight helpers
# ---------------------------------------------------------------------------

gpu_drm_device_paths() {
  local sysfs_base="$1"
  local drm_dir entry devnode
  drm_dir="${sysfs_base}/drm"
  [[ -d "${drm_dir}" ]] || return 0
  for entry in "${drm_dir}"/card* "${drm_dir}"/renderD*; do
    [[ -e "${entry}" ]] || continue
    devnode="/dev/$(basename "${entry}")"
    [[ -e "${devnode}" ]] && printf '%s\n' "${devnode}"
  done
}

nvidia_device_minor_for_pci() {
  local info_file="$1"
  [[ -f "${info_file}" ]] || return 0
  awk -F': *' '/Device Minor/ {print $2; exit}' "${info_file}" 2>/dev/null || true
}

gpu_device_paths() {
  local sysfs_base info_file minor
  [[ -n "${GPU_PCI:-}" ]] || return 0
  sysfs_base="/sys/bus/pci/devices/${GPU_PCI}"
  [[ -d "${sysfs_base}" ]] || return 0
  gpu_drm_device_paths "${sysfs_base}"
  info_file="/proc/driver/nvidia/gpus/${GPU_PCI}/information"
  minor="$(nvidia_device_minor_for_pci "${info_file}")"
  if [[ "${minor}" =~ ^[0-9]+$ ]] && [[ -e "/dev/nvidia${minor}" ]]; then
    printf '%s\n' "/dev/nvidia${minor}"
  fi
}

gpu_consumer_pids_for_paths() {
  local -a devices=("$@")
  if command -v fuser >/dev/null 2>&1; then
    [[ "${#devices[@]}" -gt 0 ]] || return 0
    run_maybe_sudo fuser "${devices[@]}" 2>/dev/null | grep -Eo '[0-9]+' | sort -u || true
  fi
}

gpu_consumer_cgroup() {
  local pid="$1"
  cat "/proc/${pid}/cgroup" 2>/dev/null || true
}

gpu_consumer_origin() {
  local pid="$1"
  local cgroup
  cgroup="$(gpu_consumer_cgroup "${pid}")"
  if [[ "${cgroup}" == *docker* ]]; then
    printf 'docker container\n'
  elif [[ "${cgroup}" == *containerd* ]]; then
    printf 'containerd container\n'
  elif [[ "${cgroup}" == *kubepods* ]]; then
    printf 'kubernetes pod\n'
  elif [[ "${cgroup}" == *libpod* || "${cgroup}" == *podman* ]]; then
    printf 'podman container\n'
  elif [[ "${cgroup}" == *user.slice* ]]; then
    printf 'user session\n'
  else
    printf 'host process\n'
  fi
}

gpu_container_id() {
  local pid="$1"
  local cgroup
  cgroup="$(gpu_consumer_cgroup "${pid}")"
  printf '%s\n' "${cgroup}" | grep -Eo '[0-9a-f]{64}|[0-9a-f]{32}' | tail -n1 || true
}

gpu_container_runtime() {
  local pid="$1"
  local cgroup
  cgroup="$(gpu_consumer_cgroup "${pid}")"
  if [[ "${cgroup}" == *docker* ]]; then
    printf 'docker\n'
  elif [[ "${cgroup}" == *libpod* || "${cgroup}" == *podman* ]]; then
    printf 'podman\n'
  fi
}

gpu_container_ref() {
  local pid="$1"
  local runtime id
  runtime="$(gpu_container_runtime "${pid}")"
  id="$(gpu_container_id "${pid}")"
  [[ -n "${runtime}" && -n "${id}" ]] && printf '%s:%s\n' "${runtime}" "${id}"
}

container_display_name() {
  local runtime="$1" id="$2" name=""
  case "${runtime}" in
    docker)
      command -v docker >/dev/null 2>&1 &&
        name="$(run_maybe_sudo docker inspect --format '{{.Name}}' "${id}" 2>/dev/null | sed 's#^/##' || true)"
      ;;
    podman)
      command -v podman >/dev/null 2>&1 &&
        name="$(run_maybe_sudo podman inspect --format '{{.Name}}' "${id}" 2>/dev/null || true)"
      ;;
  esac
  [[ -n "${name}" ]] && printf '%s\n' "${name}" || printf '%s\n' "${id:0:12}"
}

print_gpu_consumers() {
  local -a pids=("$@")
  local pid user comm origin
  for pid in "${pids[@]}"; do
    [[ -d "/proc/${pid}" ]] || continue
    user="$(ps -o user= -p "${pid}" 2>/dev/null | awk '{print $1}' || true)"
    comm="$(ps -o comm= -p "${pid}" 2>/dev/null | sed 's/^[[:space:]]*//' || true)"
    origin="$(gpu_consumer_origin "${pid}")"
    printf '  - pid %s  user=%s  cmd=%s  origin=%s\n' \
      "${pid}" "${user:-unknown}" "${comm:-unknown}" "${origin}"
  done
}

stop_container_ref() {
  local ref="$1" runtime id
  runtime="${ref%%:*}"
  id="${ref#*:}"
  case "${runtime}" in
    docker) command -v docker >/dev/null 2>&1 && run_maybe_sudo docker stop -t 15 "${id}" >/dev/null ;;
    podman) command -v podman >/dev/null 2>&1 && run_maybe_sudo podman stop -t 15 "${id}" >/dev/null ;;
    *) return 1 ;;
  esac
}

kill_gpu_consumers() {
  local -a pids=("$@")
  [[ "${#pids[@]}" -gt 0 ]] || return 0
  run_maybe_sudo kill -TERM "${pids[@]}" 2>/dev/null || true
  sleep 2
  run_maybe_sudo kill -KILL "${pids[@]}" 2>/dev/null || true
}

preflight_gpu_release() {
  local -a devices=() pids=() containers=() container_refs=() remaining=()

  mapfile -t devices < <(gpu_device_paths)
  [[ "${#devices[@]}" -gt 0 ]] || return 0

  mapfile -t pids < <(gpu_consumer_pids_for_paths "${devices[@]}")
  [[ "${#pids[@]}" -gt 0 ]] || return 0

  echo "GPU preflight: passthrough GPU ${GPU_PCI:-} is still in use."
  echo "Resolved device nodes:"
  printf '  - %s\n' "${devices[@]}"
  echo
  echo "Processes still holding the GPU:"
  print_gpu_consumers "${pids[@]}"
  echo

  if [[ "${MODE:-single}" == "single" ]]; then
    echo "Single-GPU mode — the libvirt hook will evict GPU users, but some may need manual cleanup."
  else
    echo "Dedicated-GPU mode — the passthrough GPU is unexpectedly busy."
  fi

  # Collect container refs (deduplicated)
  local pid ref
  for pid in "${pids[@]}"; do
    ref="$(gpu_container_ref "${pid}" || true)"
    [[ -n "${ref}" ]] && container_refs+=("${ref}")
  done
  mapfile -t containers < <(printf '%s\n' "${container_refs[@]}" | sort -u)

  if [[ "${#containers[@]}" -gt 0 ]]; then
    echo
    echo "Detected containers using the GPU:"
    local r i
    for r in "${containers[@]}"; do
      runtime="${r%%:*}"; i="${r#*:}"
      printf '  - %s  %s  id=%s\n' "${runtime}" "$(container_display_name "${runtime}" "${i}")" "${i:0:12}"
    done
    echo
    if confirm "Try to stop these containers gracefully first?" "y"; then
      local c
      for c in "${containers[@]}"; do
        stop_container_ref "${c}" || true
      done
      sleep 2
      mapfile -t pids < <(gpu_consumer_pids_for_paths "${devices[@]}")
      [[ "${#pids[@]}" -gt 0 ]] || return 0
      echo "Still present after graceful container stop:"
      print_gpu_consumers "${pids[@]}"
      echo
    fi
  fi

  if ! confirm "Force-kill these GPU users before starting ${VM_NAME}?" "n"; then
    echo "Start cancelled."
    return 1
  fi

  kill_gpu_consumers "${pids[@]}"
  mapfile -t remaining < <(gpu_consumer_pids_for_paths "${devices[@]}")
  [[ "${#remaining[@]}" -gt 0 ]] || return 0

  echo "Some GPU users are still present after force-kill:"
  print_gpu_consumers "${remaining[@]}"
  echo
  echo "Starting ${VM_NAME} may still fail until those processes release the GPU."
  confirm "Continue and let the libvirt hook make the final attempt?" "n"
}

# ---------------------------------------------------------------------------
# Viewer / domain helpers
# ---------------------------------------------------------------------------

can_launch_viewer() {
  [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ]]
}

launch_spice_viewer() {
  can_launch_viewer || {
    echo "VM is running. Open it with virt-manager or virt-viewer." >&2
    return 0
  }
  if command -v virt-viewer >/dev/null 2>&1; then
    nohup virt-viewer --connect "${URI}" "${VM_NAME}" >/dev/null 2>&1 &
    echo "Opening ${VM_NAME} in virt-viewer..."
    return 0
  fi
  if command -v remote-viewer >/dev/null 2>&1; then
    nohup remote-viewer "spice://localhost?title=${VM_NAME}" >/dev/null 2>&1 &
    echo "Opening ${VM_NAME} in remote-viewer..."
    return 0
  fi
  if command -v virt-manager >/dev/null 2>&1; then
    nohup virt-manager --connect "${URI}" --show-domain-console "${VM_NAME}" >/dev/null 2>&1 &
    echo "Opening ${VM_NAME} in virt-manager..."
    return 0
  fi
  echo "VM is running. Open it with virt-manager or virt-viewer." >&2
}

# ---------------------------------------------------------------------------
# Sunshine / Moonlight headless streaming
# ---------------------------------------------------------------------------
print_sunshine_hint() {
  local host_ip
  host_ip="$(ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if ($i=="src") {print $(i+1); exit}}')"
  host_ip="${host_ip:-<host-ip>}"
  echo
  echo "  Sunshine / Moonlight Streaming"
  echo "  ───────────────────────────────────────────────────────"
  echo "  1. Ensure Sunshine is installed and running inside the Windows VM."
  echo "     → https://github.com/LizardByte/Sunshine/releases"
  echo
  echo "  2. Open Moonlight on any client and add this host:"
  echo "       ${host_ip}"
  echo
  echo "  3. If Windows shows a black screen / low resolution:"
  echo "     → Install the Sunshine Virtual Display driver (built-in from v0.23+)"
  echo "       OR use a cheap dummy HDMI/DisplayPort plug (~\$5)"
  echo
  echo "  4. Sunshine web UI (inside VM, or via port-forward):"
  echo "       https://${host_ip}:47990"
  echo "  ───────────────────────────────────────────────────────"
  echo
}

stream_mode() {
  # Start VM headlessly (no Spice viewer) — designed for Sunshine/Moonlight use.
  local state stage xml
  state="$(vm_state)"
  stage="$(infer_stage)"

  if [[ "${state}" == "running" ]]; then
    echo "${VM_NAME} is already running in headless mode."
    print_sunshine_hint
    return 0
  fi

  case "${stage}" in
    host-configured)
      echo "VM not yet created. Run 'windows-vm start' first to complete the install phase."
      exit 1
      ;;
    spice-install)
      echo "VM is in the Spice install phase — complete Windows setup first."
      echo "Run:  windows-vm start    (opens Spice viewer for install)"
      echo "Then: windows-vm attach-gpu  (finalize passthrough)"
      echo "Then: windows-vm stream   (next time)"
      exit 1
      ;;
    gpu-passthrough)
      xml="$(domain_xml)"
      if ! xml_has_gpu_hostdev "${xml}"; then
        echo "Refusing to start: ${VM_NAME} does not have the configured GPU attached." >&2
        exit 1
      fi
      if xml_has_spice_qxl "${xml}"; then
        echo "Stale Spice/QXL config detected — reconciling..."
        passthrough_attach_gpu
      fi
      ;;
  esac

  preflight_gpu_release || exit 1
  virsh -c "${URI}" start "${VM_NAME}"
  echo "${VM_NAME} started in headless mode."
  print_sunshine_hint
}

vm_state() {
  virsh -c "${URI}" domstate "${VM_NAME}" 2>/dev/null || true
}

domain_exists() {
  virsh -c "${URI}" dominfo "${VM_NAME}" >/dev/null 2>&1
}

domain_xml() {
  virsh -c "${URI}" dumpxml "${VM_NAME}" 2>/dev/null || true
}

xml_has_gpu_hostdev() {
  local xml="$1"
  [[ -n "${GPU_PCI:-}" ]] || return 1
  printf '%s' "${xml}" | grep -Fq \
    "domain='0x${GPU_PCI:0:4}' bus='0x${GPU_PCI:5:2}' slot='0x${GPU_PCI:8:2}' function='0x${GPU_PCI:11:1}'"
}

xml_has_spice_qxl() {
  local xml="$1"
  printf '%s' "${xml}" | grep -Eq "<graphics type='spice'|<video>|<channel type='spicevmc'|<redirdev "
}

# ---------------------------------------------------------------------------
# Stage inference
# ---------------------------------------------------------------------------

infer_stage() {
  # Use the state file if reliable, otherwise infer from libvirt domain state.
  local recorded_stage="${INSTALL_STAGE:-}"

  if ! domain_exists; then
    printf 'host-configured\n'
    return 0
  fi

  local xml
  xml="$(domain_xml)"

  if xml_has_gpu_hostdev "${xml}"; then
    printf 'gpu-passthrough\n'
    return 0
  fi

  # Domain exists but no GPU — must be in Spice install phase
  printf 'spice-install\n'
}

print_next_step() {
  case "$(infer_stage)" in
    host-configured)
      echo "Next step: run ./windows"
      echo "  Creates the first-boot Spice install VM."
      ;;
    spice-install)
      echo "Next step: run ./windows"
      echo "  If VM is shut down, you'll be asked to resume or finalize."
      ;;
    gpu-passthrough)
      echo "Next step: run ./windows"
      echo "  Starts the finalized GPU passthrough VM directly."
      ;;
    *)
      echo "Unknown stage. Check ${STATE_FILE}."
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Main stage router
# ---------------------------------------------------------------------------

run_stage_action() {
  local state stage xml
  state="$(vm_state)"
  stage="$(infer_stage)"

  case "${stage}" in
    host-configured)
      passthrough_create_vm
      exit 0
      ;;
    spice-install)
      case "${state}" in
        running)
          echo "${VM_NAME} is running in the Spice install phase."
          launch_spice_viewer
          exit 0
          ;;
        "shut off"|"")
          if confirm "Windows install VM is shut down. Resume the Spice install?" "y"; then
            virsh -c "${URI}" start "${VM_NAME}"
            launch_spice_viewer
            exit 0
          fi
          if confirm "Finalize: switch ${VM_NAME} to GPU passthrough now?" "n"; then
            passthrough_attach_gpu
            xml="$(domain_xml)"
            if xml_has_spice_qxl "${xml}"; then
              echo "Warning: VM still has Spice/QXL after attach — something went wrong." >&2
              exit 1
            fi
            preflight_gpu_release || exit 1
            exec virsh -c "${URI}" start "${VM_NAME}"
          fi
          echo "Leaving ${VM_NAME} shut down."
          exit 0
          ;;
        *)
          virsh -c "${URI}" start "${VM_NAME}"
          launch_spice_viewer
          exit 0
          ;;
      esac
      ;;
    gpu-passthrough)
      xml="$(domain_xml)"
      if ! xml_has_gpu_hostdev "${xml}"; then
        echo "Refusing to start: ${VM_NAME} does not have the configured GPU attached." >&2
        echo "Inspect with: ./windows xml" >&2
        exit 1
      fi
      if xml_has_spice_qxl "${xml}"; then
        echo "Stale mixed VM config detected — reconciling passthrough settings."
        passthrough_attach_gpu
      fi
      if [[ "${state}" == "running" ]]; then
        echo "${VM_NAME} is already running."
        exit 0
      fi
      preflight_gpu_release || exit 1
      exec virsh -c "${URI}" start "${VM_NAME}"
      ;;
    *)
      echo "Unknown install stage: ${stage}" >&2
      exit 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Command dispatch
# ---------------------------------------------------------------------------

case "${ACTION}" in
  go|start)
    run_stage_action
    ;;
  create|install)
    passthrough_create_vm "${2:-}" "${3:-}"
    ;;
  attach-gpu|finalize)
    passthrough_attach_gpu
    ;;
  stop|shutdown)
    exec virsh -c "${URI}" shutdown "${VM_NAME}"
    ;;
  destroy)
    exec virsh -c "${URI}" destroy "${VM_NAME}"
    ;;
  reset)
    exec virsh -c "${URI}" reset "${VM_NAME}"
    ;;
  reboot)
    exec virsh -c "${URI}" reboot "${VM_NAME}"
    ;;
  stream|headless)
    stream_mode
    ;;
  sunshine)
    print_sunshine_hint
    ;;
  status)
    echo "install_stage=$(infer_stage)"
    print_next_step
    echo
    exec virsh -c "${URI}" domstate "${VM_NAME}"
    ;;
  next)
    print_next_step
    ;;
  xml)
    exec virsh -c "${URI}" dumpxml "${VM_NAME}"
    ;;
  help|--help|-h)
    head -n 15 "${BASH_SOURCE[0]}" | grep '^#' | sed 's/^# \?//'
    ;;
  *)
    echo "usage: windows [go|start|create|install|attach-gpu|finalize|stop|shutdown|destroy|reset|reboot|status|next|xml]" >&2
    exit 2
    ;;
esac
